# =============================================================================
# CSW Blast Radius Demo — Credentials (template)
#
# Copy to .env and fill in your CSW API credentials. NEVER commit .env;
# it is excluded by .gitignore.
#   cp .env.example .env
# =============================================================================

# ---- Required ---------------------------------------------------------------
# CSW API credentials. Generate at:  CSW UI > Platform > API Keys > Create
# Your key needs at least these capabilities:
#   - app_policy_management   (scopes, workspaces, policies, enforcement)
#   - user_data_upload        (inventory label upload from Phase 1)
#   - sensor_management       (read agent status from Phase 2)
CSW_API_KEY=replace_with_your_api_key
CSW_API_SECRET=replace_with_your_api_secret

# CSW SaaS tenant hostname — must match the host shown in the CSW UI URL.
# No scheme (https://), no path. Example: customer.tetrationcloud.com
CSW_TENANT=your-cluster.tetrationcloud.com

# ---- Optional ---------------------------------------------------------------
# Disable TLS verification ONLY for self-signed lab clusters or behind a
# corporate TLS-inspection proxy. Default is to verify.
# CSW_VERIFY_SSL=false
