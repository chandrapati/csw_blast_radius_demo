# =============================================================================
# 05_demo_builder - Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to Git. It is in .gitignore.
# =============================================================================

# Your CSW API credentials
# Generate at: Platform > API Keys > Create API Key
# Required capabilities: app_policy_management, user_data_upload, sensor_management
CSW_API_KEY=yourkey
CSW_API_SECRET=yoursecret

# Your CSW SaaS tenant hostname (matches config.yaml)
CSW_TENANT=kubuspov.tetrationcloud.com
