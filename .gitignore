# =============================================================================
# CSW Blast Radius Demo — Git ignore rules
# =============================================================================

# ---- Secrets / tenant-specific files (never commit) -------------------------
.env
config.yaml
tetration_installer.sh

# ---- OS noise ---------------------------------------------------------------
.DS_Store
Thumbs.db

# ---- Python -----------------------------------------------------------------
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/

# ---- Local logs / scratch ---------------------------------------------------
*.log
.tmp/
